# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# claude code local settings (personal, not shared)
.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts

# primary text library (source PDFs/epubs) — feeds Source Management (Build
# Order item 7) eventually, but too large/binary-heavy for git
/Sources/
